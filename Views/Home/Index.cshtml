@model IEnumerable<Digital_Art_Kursoviy_Project.Models.Artwork>
@{
    ViewData["Title"] = "Головна";
}

<div class="text-center mb-5 mt-5">
    <h1 class="luxury-title mb-3">Ласкаво просимо до @ViewBag.GalleryName</h1>
    <p class="luxury-subtitle lead">Відкрийте для себе найкращі твори сучасного мистецтва.</p>
</div>

<div class="search-section mb-5 p-4" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; backdrop-filter: blur(10px);">
    <form asp-controller="Home" asp-action="Index" method="get" class="row g-3 align-items-center">

        <div class="col-md-3">
	        <select name="searchType" class="form-control luxury-input" style="background-color: #121212; color: white;">
		        <option value="author" selected="@(ViewBag.CurrentSearchType == "author")">Шукати за Автором</option>
		        <option value="technique" selected="@(ViewBag.CurrentSearchType == "technique")">Шукати за Технікою</option>
		        <option value="title" selected="@(ViewBag.CurrentSearchType == "title")">Шукати за Назвою</option>
		        <option value="type" selected="@(ViewBag.CurrentSearchType == "type")">Шукати за Напрямком</option>
	        </select>
        </div>

        <div class="col-md-7">
            <input type="text" name="searchQuery" value="@ViewBag.CurrentSearchQuery" class="form-control luxury-input" placeholder="Що шукаємо? (наприклад: Олія, Ван Гог...)" />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-light w-100 text-uppercase" style="letter-spacing: 1px;">Знайти</button>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(ViewBag.CurrentSearchQuery))
    {
        <div class="mt-3 text-end">
            <a asp-action="Index" class="text-white-50 text-decoration-none" style="letter-spacing: 1px;">
                <small>✖ Скинути результати</small>
            </a>
        </div>
    }
</div>

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm" style="background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1);">

                    <a asp-action="Details" asp-route-id="@item.Id" class="d-block text-decoration-none">
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="object-fit: cover; height: 250px; width: 100%; transition: opacity 0.3s;" onmouseover="this.style.opacity=0.8" onmouseout="this.style.opacity=1" />
                    </a>

                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                <h5 class="card-title fw-bold text-white mb-3" style="transition: color 0.3s;" onmouseover="this.style.color='#aaa'" onmouseout="this.style.color='white'">@item.Title</h5>
                            </a>
                        </div>

                        <div class="d-flex align-items-center mt-auto border-top pt-3" style="border-color: rgba(255,255,255,0.1) !important;">
                            @if (item.Artist != null && !string.IsNullOrEmpty(item.Artist.PhotoUrl))
                            {
                                <img src="@item.Artist.PhotoUrl" alt="@item.Artist.FullName" class="rounded-circle me-2" style="width: 35px; height: 35px; object-fit: cover; border: 1px solid rgba(255,255,255,0.3);" />
                            }
                            else
                            {
                                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center me-2 text-white fw-bold" style="width: 35px; height: 35px; font-size: 0.9rem; background: rgba(255,255,255,0.1) !important; border: 1px solid rgba(255,255,255,0.2);">
                                    @(item.Artist?.FullName?.Substring(0, 1).ToUpper() ?? "?")
                                </div>
                            }

                            <div style="line-height: 1.2;">
                                <p class="text-white mb-0" style="font-size: 0.9rem; font-weight: 400;">@item.Artist?.FullName</p>
                                <p class="text-white-50 mb-0" style="font-size: 0.75rem;"><small>Рік: @item.CreationYear</small></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else if (!string.IsNullOrEmpty(ViewBag.CurrentSearchQuery))
    {
        <div class="col-12 text-center mt-4">
            <p class="text-white-50">За вашим запитом нічого не знайдено.</p>
        </div>
    }
</div>

<style>
    .luxury-input {
        background-color: transparent !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        color: white !important;
        border-radius: 0;
    }

        .luxury-input:focus {
            box-shadow: none !important;
            border-color: rgba(255, 255, 255, 0.8) !important;
        }

        .luxury-input::placeholder {
            color: rgba(255, 255, 255, 0.4) !important;
        }

    select option {
        background-color: #1a1a1a !important;
        color: white !important;
    }
</style>
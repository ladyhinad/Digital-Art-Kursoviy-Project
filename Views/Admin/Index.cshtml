@{
    ViewData["Title"] = "Адмін-панель";
}

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-5 border-bottom pb-3">
        <h2 style="font-weight: 300; letter-spacing: 1px; margin-bottom: 0;">Керування галереєю</h2>
        <a asp-controller="Admin" asp-action="Logout" class="btn btn-sm btn-outline-danger">Вийти з системи</a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 style="font-weight: 300;">Твори мистецтва</h4>
        <a asp-controller="Admin" asp-action="CreateArtwork" class="btn btn-outline-light">Додати новий твір</a>
    </div>

    <div class="table-responsive mb-5">
        <table class="table table-dark table-hover" style="background: rgba(0,0,0,0.4); backdrop-filter: blur(10px);">
            <thead>
                <tr style="color: rgba(255,255,255,0.6);">
                    <th>ID</th>
                    <th>Назва</th>
                    <th>Автор</th>
                    <th>Рік</th>
                    <th class="text-end">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in ViewBag.Artworks)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-bold">@item.Title</td>
                        <td>@item.Artist?.FullName</td>
                        <td>@item.CreationYear</td>
                        <td class="text-end">
                            <a asp-controller="Admin" asp-action="EditArtwork" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning me-2">Редагувати</a>
                            <a asp-controller="Admin" asp-action="DeleteArtwork" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Ви впевнені, що хочете видалити цей твір з експозиції?');">Видалити</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 style="font-weight: 300;">Реєстр митців</h4>
        <a asp-controller="Admin" asp-action="CreateArtist" class="btn btn-outline-light">Додати митця</a>
    </div>

    <div class="table-responsive mb-5">
        <table class="table table-dark table-hover" style="background: rgba(0,0,0,0.4); backdrop-filter: blur(10px);">
            <thead>
                <tr style="color: rgba(255,255,255,0.6);">
                    <th>ID</th>
                    <th>ПІБ / Псевдонім</th>
                    <th>Роки життя</th>
                    <th class="text-end">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var artist in ViewBag.Artists)
                {
                    <tr>
                        <td>@artist.Id</td>
                        <td class="fw-bold">@artist.FullName</td>
                        <td>@artist.BirthYear - @(artist.DeathYear?.ToString() ?? "Наш час")</td>
                        <td class="text-end">
                            <a asp-controller="Admin" asp-action="EditArtist" asp-route-id="@artist.Id" class="btn btn-sm btn-outline-warning me-2">Редагувати</a>
                            <a asp-controller="Admin" asp-action="DeleteArtist" asp-route-id="@artist.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Увага! Видалення митця може призвести до видалення його робіт. Продовжити?');">Видалити</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>